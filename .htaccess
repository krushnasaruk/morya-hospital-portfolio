# Enable URL Rewriting
RewriteEngine On

# Protect sensitive files from public access (e.g. .env, database JSON file)
<FilesMatch "^\.env|data_records\.json$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow direct access to actual files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /admin (without file extension) to admin.html
RewriteRule ^admin$ admin.html [L]

# Route /api/<endpoint> to api.php?action=<endpoint>
# Example: /api/config -> api.php?action=config
# Example: /api/admin/appointments -> api.php?action=admin/appointments
RewriteRule ^api/(.*)$ api.php?action=$1 [QSA,L]
